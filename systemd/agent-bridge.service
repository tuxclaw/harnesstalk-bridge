[Unit]
Description=Agent Bridge MCP server
After=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/.local/share/agent-bridge-mcp
Environment=PYTHONUNBUFFERED=1
ExecStart=%h/.local/share/agent-bridge-mcp/.venv/bin/agent-bridge --config %h/.config/agent-bridge/targets.toml
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
